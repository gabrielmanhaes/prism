# Copy this to .env and fill in your keys
# At least one LLM provider is required for the response-level API engine
# Token-level generation uses local models and does not need API keys

# Anthropic Claude (recommended for response-level generation)
ANTHROPIC_API_KEY=

# OpenAI GPT (alternative)
OPENAI_API_KEY=

# Ollama runs locally — no key needed
# Install from https://ollama.ai and run: ollama pull mistral
